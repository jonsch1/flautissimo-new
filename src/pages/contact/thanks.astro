---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Vielen Dank | Musikhaus-Aachen"
  description="Vielen Dank für Ihre Nachricht"
>
  <div class="bg-gray-50 py-12 min-h-screen flex items-center">
    <div class="container mx-auto px-4 max-w-2xl">
      <div class="bg-white rounded-lg shadow-lg p-8 md:p-12 text-center">

        <h1 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900">
          Vielen Dank!
        </h1>

        <p class="text-xl text-gray-700 mb-8">
          Ihre Nachricht wurde erfolgreich versendet. Wir werden uns so schnell wie möglich bei Ihnen melden.
        </p>

        <div class="space-y-4">
          <a
            href="/"
            class="inline-block bg-primary hover:bg-primary-dark text-white font-bold py-3 px-8 rounded-lg transition-colors"
          >
            Zurück zur Startseite
          </a>

          <div>
            <a
              href="/contact"
              class="text-primary hover:text-primary-dark font-semibold"
            >
              Zurück zum Kontaktformular
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
